# Скопируйте этот файл в .production-credentials (он в .gitignore) и заполните
# своими значениями. Файл нужен только если вы деплоите на шаред-хостинг через
# SSH / SCP — пользователям Netlify, Vercel, Cloudflare Pages и GitHub Pages
# он не нужен.

# SSH-цель вашего шаред-хостинг-аккаунта
PROD_SSH_HOST=your-host.example.com
PROD_SSH_USER=your-username
PROD_SSH_PORT=22
PROD_SSH_KEY=~/.ssh/id_rsa

# Абсолютный путь к web root на сервере (например, /home/user/public_html)
PROD_WEB_PATH=/path/to/public_html

# Публичный URL продакшена — используется для пост-деплой проверки
PROD_URL=https://your-site.com
