# Copy this file to .production-credentials (which is gitignored) and fill in
# your own values. This file is only needed if you deploy to shared hosting via
# SSH / SCP — Netlify, Vercel, Cloudflare Pages, and GitHub Pages users can
# ignore it entirely.

# SSH target for your shared-hosting account
PROD_SSH_HOST=your-host.example.com
PROD_SSH_USER=your-username
PROD_SSH_PORT=22
PROD_SSH_KEY=~/.ssh/id_rsa

# Absolute path to the web root on the server (e.g. /home/user/public_html)
PROD_WEB_PATH=/path/to/public_html

# Public URL of your production site, used for post-deploy verification
PROD_URL=https://your-site.com
